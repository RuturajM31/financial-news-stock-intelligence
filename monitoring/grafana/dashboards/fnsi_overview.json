{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "fni_application_ready",
          "refId": "A"
        }
      ],
      "title": "API Ready",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(fni_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "title": "Requests / second",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(fni_http_requests_total{status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "5xx error rate",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "fni_http_requests_in_flight",
          "refId": "A"
        }
      ],
      "title": "In-flight requests",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum(rate(fni_http_requests_total[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by route",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fni_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "p95 request latency",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "sum(rate(fni_service_operations_total[5m])) by (operation, outcome)",
          "legendFormat": "{{operation}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Service operation outcomes",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fni_service_operation_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "title": "p95 service operation latency",
      "type": "timeseries"
    }
  ],
